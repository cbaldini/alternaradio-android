<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Borde exterior oscuro/sombra -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#000000" />
            <corners android:radius="8dp" />
        </shape>
    </item>
    <!-- Cuerpo con fondo negro profundo -->
    <item android:top="2dp" android:bottom="2dp" android:left="2dp" android:right="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#080808" />
            <stroke android:width="2dp" android:color="#330000" />
            <corners android:radius="6dp" />
        </shape>
    </item>
</layer-list>
